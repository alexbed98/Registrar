@model Models.Student
@{
    ViewBag.Action = "Create";
    Html.RenderPartial("StudentForm");
}

@section Scripts {
    <script>
        $(() => {
            newSession(620);
            initFormValidation();
            addConflictValidation(
                "/Students/EmailAvailable",
                'Email' /* field unicity check */,
                'submit' /* form submit button Id */);
        })
    </script>
}
