@model IEnumerable<Models.Teacher>

@if (Model != null && Model.Any())
{

    foreach (var teacher in Model)
    {
        <div style="display: flex; flex-direction: row; gap: 7px; padding: 5px; align-items: center;">
            <img src="@teacher.Avatar" alt="@teacher.LastName @teacher.FirstName" style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;" />
            <a href="/Teachers/Details/@teacher.Id" style="color: blue;">@teacher.Code</a>
            <div class="teacherText" style="font-weight: 500;">@teacher.LastName @teacher.FirstName</div>
        </div>

    }

}
else
{
    <p>Aucun prof...</p>
}

