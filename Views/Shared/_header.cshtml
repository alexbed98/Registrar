<!--
    Cette vue partielle a pour mission de construire l'entête et les menus en fonction de l'action
-->
@{
    string controller = HttpContext.Current.Request.RequestContext.RouteData.Values["controller"].ToString().ToLower();
    string action = HttpContext.Current.Request.RequestContext.RouteData.Values["action"].ToString().ToLower();

    int currentStudentId = Session["CurrentStudentId"] != null ? (int)Session["CurrentStudentId"] : 0;
    Student currentStudent = DAL.DB.Students.Get(currentStudentId);


    bool search = false;
    string searchString = "";

    switch (controller)
    {
        case "students":
            search = Session["StudentsSearch"] != null
                ? (bool)Session["StudentsSearch"]
                : false;

            searchString = Session["StudentsSearchString"] != null
                ? (string)Session["StudentsSearchString"]
                : "";

            break;

        case "courses":
            search = Session["CoursesSearch"] != null
                ? (bool)Session["CoursesSearch"]
                : false;

            searchString = Session["CoursesSearchString"] != null
                ? (string)Session["CoursesSearchString"]
                : "";

            break;

        case "teachers":
            search = Session["TeachersSearch"] != null
                ? (bool)Session["TeachersSearch"]
                : false;

            searchString = Session["TeachersSearchString"] != null
                ? (string)Session["TeachersSearchString"]
                : "";

            break;
    }

    var Categories = (List<string>)Session["Categories"];

    bool userConnected = Models.User.ConnectedUser != null;
    bool userIsAdmin = userConnected ? Models.User.ConnectedUser.IsAdmin : false;
    bool userCanWrite = userConnected ? Models.User.ConnectedUser.CanWrite : false;
    string index = RouteConfig.DefaultAction();

    var studentsClass = "unselectedSection";
    var coursesClass = "unselectedSection";
    var teachersClass = "unselectedSection";

    var sectionTitle = "";
    var subSectionTitle = "";

    switch (controller)
    {
        case "students":
            sectionTitle = "Étudiant";
            studentsClass = "selectedSection";
            break;
        case "courses":
            sectionTitle = "Cours";
            coursesClass = "selectedSection";
            break;
        case "teachers":
            sectionTitle = "Prof";
            teachersClass = "selectedSection";
            break;
    }

    switch (action)
    {
        case "details":
            subSectionTitle = "Détails";
            break;
        case "edit":
            subSectionTitle = "Modification";
            break;
        case "add":
            subSectionTitle = "Ajout";
            break;
    }
}

<div class="section roundedBorder">
    <div class="headerMenu">
        <i class="siteIcon"></i>

        @switch (action)
        {
            case "setyear":
                <div style="font-size: 20px; font-weight: bold;">Session courante</div>
                break;
            case "login":
                <div style="font-size: 20px; font-weight: bold;">Registrar</div>
                break;
            case "list":
                <div style="display: flex; flex-direction: row; gap: 7px;">
                    <a href="/Students/List" class="@studentsClass">Étudiants</a>
                    <a href="/Courses/List" class="@coursesClass">Cours</a>
                    <a href="/Teachers/List" class="@teachersClass">Profs</a>
                </div>
                break;
            case "details":
                <div style="font-size: 20px; font-weight: bold;">@sectionTitle - @subSectionTitle</div>
                break;
        }

        @switch (action)
        {
            case "setyear":
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a class="cmdIcon fa fa-square-xmark" title="Annuler" onclick="history.back()"></a>
                </div>
                break;
            case "login": break;
            case "subscribe":
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a class="cmdIcon fa fa-square-xmark" title="Annuler" onclick="history.back()"></a>
                </div>
                break;
            case "editprofil":
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a class="cmdIcon fa fa-square-xmark" title="Annuler" onclick="history.back()"></a>
                </div>
                break;
            case "list":
                <div id="mainMenuPanel" class="menu">
                    @if (userCanWrite)
                    {
                        <a href="/@controller/Create" class="cmdIcon fa fa-circle-plus" title="Ajouter..."></a>
                    }

                    <a href="/@controller/ToggleSearch" class="cmdIcon fa fa-search" title="Recherche..."></a>

                    <!-- Dropdown menu -->
                    <div id="menu" class="dropdown ms-auto">
                        <!-- Drop down menu acces icon -->
                        <div data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="cmdIcon fa fa-bars" title="Menu"></i>
                        </div>
                        <!-- Drop down menu items -->
                        <div class="dropdown-menu noselect" id="DDMenu" style="width:300px !important">
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-address-card"></i>
                                <a href="/Accounts/EditProfil">Profil...</a>
                            </div>
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-sign-out"></i>
                                <a href="/Accounts/Logout">Déconnexion...</a>
                            </div>
                            @if (userIsAdmin)
                            {
                                <div class="dropdown-divider"></div>

                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-users"></i>
                                    <a href="/Accounts/ManageUsers">
                                        Gestion des usagers...
                                    </a>
                                </div>
                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-calendar-days"></i>
                                    <a href="/Accounts/LoginsJournal">
                                        Historique de connexions...
                                    </a>
                                </div>
                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-gear"></i>
                                    <a href="/Accounts/EventsJournal">
                                        Journal d'activités...
                                    </a>
                                </div>
                            }

                            <div class="dropdown-divider"></div>

                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-info-circle"></i>
                                <a href="/@controller/About">À propos...</a>
                            </div>
                        </div>
                    </div>
                </div>
                break;
            case "details":
                <div id="mainMenuPanel" class="menu">
                    @if (userCanWrite)
                    {
                        string fullName = currentStudent.FirstName + " " + currentStudent.LastName;

                        <a href="/@controller/Edit" class="cmdIcon fa fa-pen-to-square" title="Modifier..."></a>

                        <i class="cmdIcon fa fa-trash-can"
                           title="Effacer"
                           onclick="bootbox.confirm(`<b style=color:red>Effacer l'étudiant : </b><h3>@fullName ?</h3>`, function(result){ if (result) window.location = '/@controller/Delete'; })">
                        </i>
                    }

                    <a href="/@controller/List" class="cmdIcon fa fa-square-xmark" title="retour"></a>
                </div>
                break;
            case "create":
                if (userCanWrite)
                {
                    <div id="mainMenuPanel" class="menu">
                        <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                        <a href="@index" class="cmdIcon fa fa-square-xmark" title="Annuler"></a>
                    </div>
                }
                break;
            case "edit":
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a href="/@controller/List" class="cmdIcon fa fa-square-xmark" title="Annuler"></a>
                </div>
                break;
            case "loginsjournal":
            case "eventsjournal":
            case "manageusers":
            case "about":
                <div id="mainMenuPanel" class="menu">
                    <a href="@index" class="cmdIcon fa fa-square-xmark" title="Retour"></a>
                </div>
                break;
        }

    </div>
</div>
@if (search && action == "list")
{
    <div class="searchBar">
        <input type="search" id="searchInput" class="section roundedBorder searchBarItem" value="@searchString" placeholder="Recherche...">
        @if (controller == "students")
        {
            <div id="yearSelectPanel" class="searchBarItem">
                    @{ Html.RenderPartial("GetYearsList"); }
            </div>
        }
    </div>
}


